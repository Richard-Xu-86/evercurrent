# EverCurrent Daily Digest — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required)
ANTHROPIC_API_KEY=
# Slack Bot Token (required for live Slack ingestion)
# Get this from api.slack.com → Your App → OAuth & Permissions → Bot OAuth Token
SLACK_BOT_TOKEN=

# Slack channels to monitor (comma-separated, no # prefix)
# Leave blank to auto-discover all public channels the bot has joined
SLACK_CHANNELS=general,mechanical,firmware,supply-chain,electrical

# How many hours back to fetch messages (default: 24)
SLACK_LOOKBACK_HOURS=24

# Server port (optional, defaults to 3000)
PORT=3000
